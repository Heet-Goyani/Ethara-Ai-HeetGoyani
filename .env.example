# --- DATABASE CONFIGURATION ---
# Local Docker DB URL: postgresql://[user]:[password]@[host]:[port]/[dbname]
DATABASE_URL=postgresql://postgres:postgres_secure_pass@db:5432/inventory_db

# --- API SERVICES ---
PROJECT_NAME="Inventory & Order Management API"
CORS_ORIGINS=["http://localhost:8080", "http://localhost:3000", "http://localhost:5173"]

# --- FRONTEND BUILD ARGUMENTS ---
# URL of your backend API (used during frontend build to bake in axios base URL)
VITE_API_URL=http://localhost:8000
